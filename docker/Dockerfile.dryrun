FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY pyproject.toml README.md /app/
COPY src /app/src

RUN pip install --no-cache-dir .

COPY docker/entrypoint-dryrun.sh /usr/local/bin/raspi-sentinel-dryrun
RUN chmod 0755 /usr/local/bin/raspi-sentinel-dryrun

ENTRYPOINT ["/usr/local/bin/raspi-sentinel-dryrun"]
